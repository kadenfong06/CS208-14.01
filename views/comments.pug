extends layout

block content
  // Comments page
  h1 Customer Comments

  // Show error message
  if error
    .error-msg(role="alert", aria-live="assertive")= error
  
  // Form to submit a comment
  form(method='POST' action='/create')
    fieldset
      legend Leave a Comment
      // Name input
      label(for='name') Name
      input(type='text', name='name', id='name', required, value=formData.name)

      // Comment input
      label(for='comment') Comment
      textarea(name='comment', id='comment', rows='4', required)= formData.comment

      button(type='submit') Submit

  hr

  if comments.length === 0
    .empty-state
      h3 No comments yet
      p Be the first to share your thoughts!
  
  each comment in comments
    .comment-card
      .comment-name= comment.name
      
      // Show readable date
      .comment-date Posted on #{new Date(comment.created_at).toLocaleString()}

      .comment-text= comment.comment
  
  // Pagination controls
  if comments.length > 0
    .pagination
      if currentPage > 1
        a(href=`/comments?page=${currentPage - 1}` aria-label="Previous page") <

      span #{currentPage} / #{totalPages}

      if currentPage < totalPages
        a(href=`/comments?page=${currentPage + 1}` aria-label="Next page") >