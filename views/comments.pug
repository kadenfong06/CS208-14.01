extends layout

block content
  // Comments page
  h1 Customer Comments

  // Show success message after submitting a comment
  if success
    .success-msg Comment posted successfully!
  
  // Form to submit a comment
  form(method='POST' action='/create')

    // Name input
    label(for='name') Name
    input(type='text', name='name', id='name', required)

    // Comment input
    label(for='comment') Comment
    textarea(name='comment', id='comment', rows='4', required)

    button(type='submit') Submit

  hr

  if comments.length === 0
    .empty-state
      h3 No comments yet
      p Be the first to share your thoughts!
  
  each comment in comments
    .comment-card
      .comment-name= comment.name
      
      // Show readable date
      .comment-date Posted on #{new Date(comment.created_at).toLocaleString()}

      .comment-text= comment.comment